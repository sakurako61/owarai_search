<div class="bg-base-200 shadow-md border-2 border-warning rounded-2xl overflow-hidden flex" style="height: 230px;">
  <!-- ポスターサムネイル（左） -->
  <div class="post-thumbnail bg-gray-100">
    <% if post.live_poster.attached? %>
      <%= image_tag post.live_poster, class: "w-full h-full object-cover" %>
    <% else %>
      <%= image_tag "post_placeholder.png", class: "w-full h-full object-cover" %>
    <% end %>
  </div>

  <!-- ライブ情報（右） -->
  <div class="flex-1 px-4 py-3 flex flex-col gap-2 min-w-0">
    <!-- タイトル -->
    <%= link_to post_path(post, q: params[:q]&.to_unsafe_h) do %>
      <h2 class="text-xl font-bold leading-snug hover:underline line-clamp-2"><%= post.live_name %></h2>
    <% end %>

    <!-- 説明 -->
    <% if post.description.present? %>
      <p class="text-sm text-gray-500 line-clamp-2"><%= post.description %></p>
    <% end %>

    <!-- 投稿者 -->
    <div class="flex items-center gap-2 mt-auto">
      <% if post.user.user_image.attached? %>
        <%= image_tag post.user.user_image, class: "rounded-full shrink-0 object-cover", style: "width: 40px; height: 40px;" %>
      <% else %>
        <div class="rounded-full shrink-0 text-gray-400" style="width: 40px; height: 40px;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
        </div>
      <% end %>
      <span class="text-sm text-gray-400 truncate"><%= post.user.name %></span>

      <% if user_signed_in? && current_user == post.user %>
        <div class="flex gap-1 ml-auto shrink-0">
          <%= link_to '編集', edit_post_path(post), class: "btn btn-xs btn-primary" %>
          <%= link_to '削除', post_path(post), data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' }, class: "btn btn-xs btn-warning" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
