<header class="flex items-center justify-between px-4 md:px-8 py-4 bg-base-300 border-b border-base-300">
  <!-- ロゴ -->
  <div class="flex items-center gap-2">
    <div class="w-8 h-8 bg-white rounded flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#facc15" class="w-5 h-5">
        <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
      </svg>
    </div>
    <span class="font-bold text-lg tracking-widest">WARAI-HUB</span>
  </div>

  <!-- ナビ（中画面以上で表示） -->
  <nav class="flex items-center gap-6 text-sm font-medium text-gray-800">
    <%= link_to 'ライブ一覧', posts_path, class: "hover:text-black transition-colors" %>
    <%= link_to '投稿する', new_post_path, class: "hover:text-black transition-colors" %>
    <!--%= link_to 'マイページ', '#', class: "hover:text-black transition-colors" %-->
  </nav>

  <!-- 右：認証ボタン + アバター -->
  <div class="flex items-center gap-3">
    <%= link_to 'ログアウト', destroy_user_session_path, data: { turbo_method: :delete }, class: "hidden md:block text-sm px-4 py-2 bg-black text-white rounded-md hover:bg-gray-800 transition-colors" %>
    <div class="avatar">
      <div class="w-12 h-12 rounded-full">
        <% if current_user.user_image.attached? %>
          <%= image_tag current_user.user_image, class: "w-full h-full object-cover" %>
        <% else %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
        <% end %>
      </div>
    </div>
    <div class="hidden md:block text-sm font-semibold truncate"><%= current_user.name %></div>
  </div>
</header>