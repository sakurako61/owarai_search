<!DOCTYPE html>
<html data-theme="warai-hub">
  <head>
    <title><%= content_for(:title) || "Owarai Search" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <!-- 重要：min-h-screen / flex / flex-col / bg-yellow-300 を body に入れる -->
  <body class="min-h-screen flex flex-col bg-base-200 antialiased text-base-content">
    <!--%= render 'shared/header', current_user: current_user %-->
    <% if user_signed_in? %>
      <%= render 'shared/header' %>
    <% else %>
      <%= render 'shared/before_login_header' %>
    <% end %>
    <!-- main は flex-1 -->
    <main class="flex-1">
      <%= render 'shared/flash_message' %>
      <%= yield %>
    </main>
    
    <%= render 'shared/footer' %>
  </body>
</html>
