<style>
  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }
  @media (min-width: 768px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .post-thumbnail {
    aspect-ratio: 3 / 4;
    height: 100%;
    flex-shrink: 0;
    overflow: hidden;
  }
</style>
<div class="container mx-auto px-4 pt-3 mb-8">
  <div class="row">
    <!--div class="col-lg-10 offset-lg-1">
      < 検索フォーム >
      <form>
        <div class="input-group mb-3"><input class="form-control" placeholder="検索ワード" type="search"/>
          <div class="input-group-append"><input type="submit" value="検索" class="btn btn-primary"/></div>
        </div>
      </form>
    </div-->
  </div>
  <!-- 掲示板一覧 -->
  <div class="post-grid">
    <% if @posts.present? %>
      <%= render partial: 'post', collection: @posts %>
    <% else %>
      <div class="col-span-3">投稿がありません</div>
    <% end %>
  </div>
</div>