<section class="min-h-[calc(100vh-130px)] flex items-center px-16 py-12">
  <div class="flex gap-12 items-center w-full max-w-6xl mx-auto">

    <!-- 左：ライブ情報カード -->
    <div class="w-80 h-72 relative rounded-2xl overflow-hidden shadow-xl flex-shrink-0 bg-gray-900">
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
      <div class="absolute inset-0 flex items-center justify-center text-white/20 text-6xl">🎭</div>
      <div class="absolute bottom-0 left-0 right-0 z-20 p-5">
        <p class="text-warning text-xs font-semibold tracking-widest mb-1">LIVE INFO</p>
        <p class="text-white font-bold text-sm leading-snug">新宿ルミネ the よしもと：当日券わずか！</p>
      </div>
    </div>

    <!-- 右：テキスト + ボタン -->
    <div class="flex-1">
      <span class="inline-block text-xs font-medium bg-white/60 px-3 py-1 rounded-full mb-5">
        Comedian Community App
      </span>
      <h1 class="text-5xl font-bold leading-tight text-black mb-4">
        笑いの情報を、<br>もっと身近に。
      </h1>
      <p class="text-black/70 text-sm leading-relaxed mb-8 max-w-md">
        全国の芸人ライブ情報を見つけて、シェア・お気に入り登録ができるコミュニティ。あなたの「推し」の出番を見逃さない。
      </p>
      <div class="flex gap-4">
        <%= link_to root_path, class: "flex items-center gap-2 bg-black text-white text-sm font-medium px-6 py-3 rounded-full hover:bg-gray-800 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z" />
          </svg>
          公演を探す
        <% end %>
        <% if user_signed_in? %>
          <button class="flex items-center gap-2 bg-black/10 text-black text-sm font-medium px-6 py-3 rounded-full hover:bg-black/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
            お気に入り登録
          </button>
        <% else %>
          <button disabled class="flex items-center gap-2 bg-black/10 text-black/40 text-sm font-medium px-6 py-3 rounded-full cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
            <span>お気に入り登録<span class="text-xs ml-1">（要ログイン）</span></span>
          </button>
        <% end %>
      </div>
    </div>

  </div>
</section>
