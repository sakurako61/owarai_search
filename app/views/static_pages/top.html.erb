<section class="min-h-[calc(100vh-130px)] flex items-center px-16 py-12">
  <div class="flex gap-12 items-center w-full max-w-6xl mx-auto">
    <div class="flex-1">
      <span class="inline-block text-xs font-medium bg-white/60 px-3 py-1 rounded-full mb-5">
        Comedian Community App
      </span>
      <h1 class="text-5xl font-bold leading-tight text-black mb-4">
        笑いの情報を、<br>もっと身近に。
      </h1>
      <p class="text-black/70 text-sm leading-relaxed mb-8 max-w-md">
        全国の芸人ライブ情報を見つけて、シェア・お気に入り登録ができるコミュニティ。あなたの「推し」の出番を見逃さない。
      </p>
      <div class="flex gap-4">
        <%= link_to root_path, class: "flex items-center gap-2 bg-black text-white text-sm font-medium px-6 py-3 rounded-full hover:bg-gray-800 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z" />
          </svg>
          公演を探す
        <% end %>
      </div>
    </div>

  </div>
</section>
