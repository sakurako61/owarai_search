<style>
  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }
  @media (min-width: 768px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .post-thumbnail {
    aspect-ratio: 3 / 4;
    height: 100%;
    flex-shrink: 0;
    overflow: hidden;
  }
</style>
<div class="container mx-auto px-4 pt-3 mb-8">
  <div class="flex justify-center mb-4">
    <!-- 検索フォーム -->
    <%= search_form_for @q, url: posts_path, class: "flex w-full max-w-3xl" do |f| %>
      <%= f.search_field :performers_comedian_name_cont, class: "input input-warning flex-1 h-10 bg-base-200 rounded-r-none", style: "--input-color: var(--color-warning); box-shadow: 0 0 0 1px var(--color-warning) inset", placeholder: "出演者名で検索" %>
      <%= f.submit "検索", class: "btn btn-primary h-10 rounded-l-none" %>
    <% end %>
  </div>
  <!-- 掲示板一覧 -->
  <div class="post-grid">
    <% if @posts.present? %>
      <%= render partial: 'post', collection: @posts %>
    <% else %>
      <div class="col-span-3">投稿がありません</div>
    <% end %>
  </div>
</div>