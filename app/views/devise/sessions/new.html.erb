<div class="px-4">
  <div class="card w-full max-w-md mx-auto bg-base-100 shadow-2xl">
    <div class="card-body p-8">
      <h2 class="card-title text-2xl justify-center mb-6">ログイン</h2>

      <%= form_with(model: resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">

          <div class="form-control">
            <%= f.label :email, "メールアドレス", class: "label py-1" %>
            <%= f.email_field :email,
                  autofocus: true,
                  autocomplete: "email",
                  class: "input input-bordered border border-base-300 w-full h-12" %>
          </div>

          <div class="form-control">
            <%= f.label :password, "パスワード", class: "label py-1" %>
            <%= f.password_field :password,
                  autocomplete: "current-password",
                  class: "input input-bordered border border-base-300 w-full h-12" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="form-control">
              <label class="label cursor-pointer justify-start gap-3">
                <%= f.check_box :remember_me, class: "checkbox checkbox-sm" %>
                <span class="label-text">ログイン状態を保持する</span>
              </label>
            </div>
          <% end %>

          <div class="form-control pt-2">
            <%= f.submit "ログイン", class: "btn btn-primary w-full h-12" %>
          </div>

        </div>
      <% end %>

      <div class="divider my-6"></div>
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>